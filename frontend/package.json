{
  "name": "snippetbox",
  "version": "0.1.0",
  "description": "A lightweight code snippet management tool for developers",
  "main": "dist/main/main/index.js",
  "author": "SnippetBox Team - Group 17 (王欣鹏, 付佳腾, 赵祐晟)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wang-xin-peng/SnippetBox.git"
  },
  "keywords": [
    "snippet",
    "code-management",
    "electron",
    "react",
    "typescript",
    "developer-tools"
  ],
  "scripts": {
    "rebuild": "electron-rebuild",
    "clean": "rimraf dist node_modules/.cache",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "npm run build:main && wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "watch:main": "tsc -p tsconfig.main.json --watch",
    "package": "npm run build && electron-builder",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "update-categories": "npm run build:main && node dist/main/main/scripts/updateCategories.js",
    "regenerate-vectors": "npm run build:main && node dist/main/main/scripts/regenerateVectors.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@mapbox/node-pre-gyp": "^2.0.3",
    "@monaco-editor/react": "^4.7.0",
    "@xenova/transformers": "^2.17.2",
    "antd": "^6.3.6",
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "onnxruntime-node": "^1.24.3",
    "pdfkit": "^0.15.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "snippetbox": "file:"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.10.0",
    "@types/pdfkit": "^0.13.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "electron-devtools-installer": "^3.2.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fast-check": "^4.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "node-gyp": "^11.5.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.snippetbox.app",
    "productName": "SnippetBox",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asar": false,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "npmRebuild": false
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
