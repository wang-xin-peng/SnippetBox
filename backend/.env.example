# 应用配置
APP_NAME=SnippetBox API
VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# CORS 配置
CORS_ORIGINS=["http://localhost:3000", "http://your_server_ip:port"]

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/snippetbox

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# 向量搜索配置
VECTOR_SEARCH_LIMIT=10
VECTOR_SIMILARITY_THRESHOLD=0.7

# 速率限制
RATE_LIMIT_PER_MINUTE=60

# JWT 配置 
JWT_SECRET_KEY=CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_IMMEDIATELY
JWT_ALGORITHM=HS256

# 短链接配置
BASE_URL=http://localhost:8000

# SMTP 邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=your_email@example.com
